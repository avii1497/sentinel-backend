APP_ENV=production
DB_HOST=your-db-host
DB_PORT=3306
DB_NAME=your-db-name
DB_USER=your-db-user
DB_PASS=your-db-password
DB_CHARSET=utf8mb4
ADMIN_JWT_SECRET=replace-with-strong-secret
ADMIN_JWT_TTL=21600
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=tls
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password
SMTP_FROM_EMAIL=mailer@example.com
SMTP_FROM_NAME=Sentinel
ADMIN_BOOTSTRAP_EMAIL=admin@example.com
ADMIN_BOOTSTRAP_PASSWORD=replace-with-strong-password
STRIPE_SECRET_KEY=sk_live_replace_me
STRIPE_WEBHOOK_SECRET=whsec_replace_me
OPENROUTER_API_KEY=replace-with-openrouter-key
NOMINATIM_EMAIL=you@example.com
NOMINATIM_USER_AGENT=sentinel-property-app
FRONTEND_ORIGINS=http://localhost:5173
