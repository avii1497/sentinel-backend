<IfModule mod_headers.c>
    Header always set Access-Control-Allow-Origin "https://relaxed-tartufo-866a0b.netlify.app"
    Header always set Access-Control-Allow-Credentials "true"
    Header always set Access-Control-Allow-Methods "GET, POST, PUT, PATCH, DELETE, OPTIONS"
    Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-CSRF-Token, X-XSRF-TOKEN, Accept"
</IfModule>

# 🔴 CRITICAL: Let OPTIONS pass instead of 404
RewriteEngine On
RewriteCond %{REQUEST_METHOD} OPTIONS
RewriteRule ^(.*)$ $1 [R=204,L]
