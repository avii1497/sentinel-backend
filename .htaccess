<IfModule mod_headers.c>
  SetEnvIfNoCase Origin "^https://musical-swan-291e56\.netlify\.app$" CORS_ALLOW_ORIGIN=$0
  SetEnvIfNoCase Origin "^http://localhost:5173$" CORS_ALLOW_ORIGIN=$0
  SetEnvIfNoCase Origin "^http://localhost:3000$" CORS_ALLOW_ORIGIN=$0
  SetEnvIfNoCase Origin "^http://localhost$" CORS_ALLOW_ORIGIN=$0
  SetEnvIfNoCase Origin "^http://127\.0\.0\.1$" CORS_ALLOW_ORIGIN=$0

  Header always set Access-Control-Allow-Origin "%{CORS_ALLOW_ORIGIN}e" env=CORS_ALLOW_ORIGIN
  Header always set Vary "Origin" env=CORS_ALLOW_ORIGIN
  Header always set Access-Control-Allow-Credentials "true"
  Header always set Access-Control-Allow-Methods "GET, POST, PUT, DELETE, OPTIONS"
  Header always set Access-Control-Allow-Headers "Content-Type, Authorization, X-Requested-With, X-CSRF-Token, X-XSRF-Token"
</IfModule>

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteCond %{REQUEST_METHOD} OPTIONS
  RewriteRule ^(.*)$ $1 [R=200,L]
</IfModule>
